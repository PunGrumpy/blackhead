{
  "name": "@repo/auth",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "migrate": "bunx --bun @better-auth/cli migrate --config server.ts",
    "generate": "bunx --bun @better-auth/cli generate --config server.ts --output ../database/prisma/schema.prisma",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/database": "*",
    "@repo/ui": "*",
    "@t3-oss/env-nextjs": "^0.12.0",
    "better-auth": "^1.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2"
  }
}
