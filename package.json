{
  "name": "blackhead",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "bump-deps": "pnpm dlx npm-check-updates --deep -u -x react-day-picker,tailwindcss && pnpm install",
    "bump-ui": "pnpm dlx shadcn@latest add --all --overwrite -c packages/ui",
    "clean": "git clean -xdf node_modules",
    "dev": "turbo dev",
    "format": "ultracite format",
    "lint": "ultracite lint",
    "migrate": "cd apps/api && pnpm dlx prisma format && pnpm dlx prisma generate && pnpm dlx prisma db push"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.4.2",
    "typescript": "5.7.3",
    "ultracite": "^4.1.20"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "core-js-pure",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
